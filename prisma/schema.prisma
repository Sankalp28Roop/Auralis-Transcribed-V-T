generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model VideoJob {
  id             String               @id @default(cuid())
  url            String
  isYouTube      Boolean              @default(true)
  transcript     String               // JSON string of Array of { start, end, text }
  rawText        String?              // Concatenated full text
  characterCount Int                  @default(0)
  processingTime Float                // In seconds
  status         String               @default("COMPLETED")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  audioJobs      AudioSynthesisJob[]
}

model AudioSynthesisJob {
  id             String    @id @default(cuid())
  voiceProfile   String
  audioUrl       String    // Local path or cloud URL to the generated mp3
  processingTime Float     // In seconds
  status         String    @default("COMPLETED")
  createdAt      DateTime  @default(now())
  
  videoJobId     String
  videoJob       VideoJob  @relation(fields: [videoJobId], references: [id], onDelete: Cascade)
}

model UserSubscription {
  id          String   @id @default("local-user")
  tier        String   @default("free") // "free" | "pro"
  licenseKey  String?
  updatedAt   DateTime @updatedAt
}

model PaymentLog {
  id            String   @id @default(cuid())
  transactionId String   @unique
  provider      String   // "simulated" | "stripe" | "razorpay"
  amount        Float
  currency      String
  status        String   // "pending" | "completed" | "failed"
  rawResponseJson String?
  createdAt     DateTime @default(now())
}

